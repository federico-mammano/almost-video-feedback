{
  "manifest_version": 3,
  "name": "Almost Video Feedback",
  "version": "0.6.0",
  "description": "Record spoken + visual feedback on any web app, then hand your AI agent one file of screenshots tied to what you said.",
  "homepage_url": "https://justinwi.github.io/almost-video-feedback/",
  "minimum_chrome_version": "116",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "downloads",
    "downloads.ui",
    "storage",
    "offscreen",
    "alarms",
    "webNavigation",
    "clipboardWrite"
  ],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'none'"
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "action": {
    "default_title": "Almost Video Feedback",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://chrome.google.com/webstore/*",
        "*://chromewebstore.google.com/*"
      ],
      "js": [
        "src/common/protocol.js",
        "src/background/loom-timeline.js",
        "src/content/overlay-style.js",
        "src/content/dom-descriptor.js",
        "src/content/gesture.js",
        "src/content/annotate.js",
        "src/content/loom-import.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://chrome.google.com/webstore/*",
        "*://chromewebstore.google.com/*"
      ],
      "js": [
        "src/common/protocol.js",
        "src/content/annotate.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "commands": {
    "toggle-recording": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Start / stop feedback recording"
    },
    "force-screenshot": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Force a screenshot now"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["src/recognizer/recognizer.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
